PAGE_CAPTURE_HOST=0.0.0.0

# Optional local override. On Railway, prefer the platform-provided PORT variable.
# PAGE_CAPTURE_PORT=3845

PAGE_CAPTURE_PUBLIC_BASE_URL=https://figmaplugin-page-capture-tool-production.up.railway.app
PAGE_CAPTURE_ALLOWED_ORIGINS=*

# Optional. If set, clients must send X-Page-Capture-Key or Authorization: Bearer.
# Do not embed a secret key in a public Community plugin build.
PAGE_CAPTURE_API_KEY=

PAGE_CAPTURE_MAX_RUNNING_JOBS=2
PAGE_CAPTURE_MAX_QUEUED_JOBS=20
PAGE_CAPTURE_JOB_RETENTION_MS=3600000
PAGE_CAPTURE_CLEANUP_INTERVAL_MS=300000
PAGE_CAPTURE_MAX_PAGE_HEIGHT=24000
PAGE_CAPTURE_MAX_REQUEST_BODY_BYTES=32768
PAGE_CAPTURE_RATE_LIMIT_WINDOW_MS=60000
PAGE_CAPTURE_RATE_LIMIT_MAX_REQUESTS=120

# Keep false for any public deployment. Enable only for trusted local/internal use.
PAGE_CAPTURE_ALLOW_PRIVATE_TARGETS=false

# Optional when Chrome/Chromium is not in a standard path.
PAGE_CAPTURE_BROWSER_PATH=
